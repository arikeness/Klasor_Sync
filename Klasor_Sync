    # ── Klasör yükleme ────────────────────────────────────────────────────
    def _karsilastir(self, klasor_adi):
        kaynak_path = os.path.join(KAYNAK, klasor_adi)
        hedef_path  = os.path.join(HEDEF,  klasor_adi)
        if not os.path.isdir(hedef_path):
            return "hedefte_yok"
        try:
            for root, _, files in os.walk(kaynak_path):
                for f in files:
                    src = os.path.join(root, f)
                    rel = os.path.relpath(src, kaynak_path)
                    dst = os.path.join(hedef_path, rel)
                    if not os.path.exists(dst) or os.path.getmtime(src) > os.path.getmtime(dst):
                        return "eksik"
            return "guncel"
        except:
            return "eksik"

    def _load_folders(self):
        self.tree.clear()
        if not os.path.isdir(KAYNAK):
            self.status.setText(f"Kaynak bulunamadı: {KAYNAK}")
            return
        try:
            klasorler = sorted(d for d in os.listdir(KAYNAK)
                               if os.path.isdir(os.path.join(KAYNAK, d)))
        except Exception as e:
            self.status.setText(f"Hata: {e}")
            return

        for k in klasorler:
            durum_key = self._karsilastir(k)
            if durum_key == "guncel":
                durum_text, fg, bg = "Güncel", QColor("#27ae60"), None
            elif durum_key == "eksik":
                durum_text, fg, bg = "Eksik / Güncel değil", QColor("#e67e22"), QColor("#fef5e7")
            else:
                durum_text, fg, bg = "Hedefte yok", QColor("#c0392b"), QColor("#fdecea")

            item = QTreeWidgetItem([k, durum_text])
            item.setForeground(0, QBrush(fg))
            item.setForeground(1, QBrush(fg))
            if bg:
                item.setBackground(0, QBrush(bg))
                item.setBackground(1, QBrush(bg))
            self.tree.addTopLevelItem(item)

        self.status.setText(f"{len(klasorler)} klasör listelendi.")

    def _select_all(self):   self.tree.selectAll()
    def _select_none(self):  self.tree.clearSelection()
    def _clear_log(self):    self.log.clear()

    # ── Senkronizasyon ────────────────────────────────────────────────────
    def _run_sync(self):
        secilen = [self.tree.topLevelItem(i).text(0)
                   for i in range(self.tree.topLevelItemCount())
                   if self.tree.topLevelItem(i).isSelected()]
        if not secilen:
            self.log.append("Lütfen en az bir klasör seçin.")
            return

        self.log_entries.clear()
        self.csv_btn.setEnabled(False)
        self.run_btn.setEnabled(False)
        self.log.clear()
        self.log.append(f"{len(secilen)} klasör senkronize ediliyor...")
        self.status.setText("Çalışıyor...")

        self.worker = SyncWorker(secilen)
        self.worker.log_signal.connect(self._handle_log)
        self.worker.done_signal.connect(self._on_done)
        self.worker.start()

    def _handle_log(self, line):
        # Satır ayrıştırma: KOPYALANDI|oyun|kaynak|hedef|tarih
        if line.startswith("KOPYALANDI|"):
            parts = line.split("|")
            if len(parts) >= 5:
                oyun, kaynak, hedef, tarih = parts[1], parts[2], parts[3], parts[4]
                dosya_adi = os.path.basename(kaynak)
                self.log_entries.append({
                    "Zaman":     datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
                    "Oyun":      oyun,
                    "Dosya":     dosya_adi,
                    "Kaynak":    kaynak,
                    "Hedef":     hedef,
                    "Tarih":     tarih,
                })
                self.log.append(f"  ✔ [{oyun}] {dosya_adi}")
        elif line.startswith("TAMAMLANDI|"):
            parts = line.split("|")
            if len(parts) >= 3:
                self.log.append(f"  → {parts[1]}: {parts[2]} dosya kopyalandı.")
        elif line.startswith("LOG|"):
            self.log.append(line[4:])
        else:
            self.log.append(line)

    def _on_done(self, success, msg):
        self.log.append(f"\n✔ {msg}")
        self.status.setText(msg)
        self.run_btn.setEnabled(True)
        if self.log_entries:
            self.csv_btn.setEnabled(True)
        self._load_folders()

    # ── CSV Export ────────────────────────────────────────────────────────
    def _export_csv(self):
        if not self.log_entries:
            self.log.append("Kaydedilecek veri yok.")
            return
        default_name = f"sync_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
        path, _ = QFileDialog.getSaveFileName(
            self, "CSV Kaydet", default_name, "CSV Dosyası (*.csv)"
        )
        if not path:
            return
        try:
            with open(path, "w", newline="", encoding="utf-8-sig") as f:
                writer = csv.DictWriter(f, fieldnames=["Zaman","Oyun","Dosya","Kaynak","Hedef","Tarih"])
                writer.writeheader()
                writer.writerows(self.log_entries)
            self.log.append(f"✔ CSV kaydedildi: {path}")
            self.status.setText(f"CSV kaydedildi: {os.path.basename(path)}")
        except Exception as e:
            self.log.append(f"CSV hatası: {e}")


