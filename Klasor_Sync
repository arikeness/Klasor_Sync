KAYNAK  = r"D:\PlayboxSIM\Oyunlar"
HEDEF   = r"D:\PlayboxSIM\Steam\steamapps\common"
FARKLAR = r"G:\OyunlarFark"


class SyncWorker(QThread):
    log_signal  = pyqtSignal(str)
    done_signal = pyqtSignal(bool, str)

    def __init__(self, secilen_klasorler):
        super().__init__()
        self.secilen = secilen_klasorler

    def run(self):
        for klasor in self.secilen:
            kaynak_yol  = os.path.join(KAYNAK,  klasor)
            hedef_yol   = os.path.join(HEDEF,   klasor)
            farklar_yol = os.path.join(FARKLAR, klasor)

            script = f"""
$kaynak  = "{kaynak_yol}"
$hedef   = "{hedef_yol}"
$farklar = "{farklar_yol}"
$dosyalar = Get-ChildItem -Path $kaynak -Recurse -ErrorAction SilentlyContinue
if (-not $dosyalar) {{ Write-Host "Bos/bulunamadi: $kaynak"; exit 0 }}
$sayac = 0
foreach ($dosya in $dosyalar) {{
    if (!$dosya.PSIsContainer) {{
        $hedefYolu = $dosya.FullName.Replace($kaynak, $hedef)
        $farkYolu  = $dosya.FullName.Replace($kaynak, $farklar)
        if (!(Test-Path $hedefYolu) -or (Get-Item $hedefYolu).LastWriteTime -lt $dosya.LastWriteTime) {{
            $yeniKlasor = Split-Path $farkYolu
            if (!(Test-Path $yeniKlasor)) {{ New-Item -ItemType Directory -Path $yeniKlasor -Force | Out-Null }}
            Copy-Item -Path $dosya.FullName -Destination $farkYolu -Force
            Write-Host "KOPYALANDI|{klasor}|$($dosya.FullName)|$farkYolu|$($dosya.LastWriteTime)"
            $sayac++
        }}
    }}
}}
Write-Host "TAMAMLANDI|{klasor}|$sayac"
"""
            try:
                with tempfile.NamedTemporaryFile(suffix=".ps1", delete=False,
                                                 mode="w", encoding="utf-8") as f:
                    f.write(script)
                    tmp = f.name

                self.log_signal.emit(f"LOG|[{klasor}] işleniyor...")

                proc = subprocess.Popen(
                    ["powershell", "-ExecutionPolicy", "Bypass",
                     "-WindowStyle", "Hidden",          # ← pencere gizli
                     "-NonInteractive",
                     "-File", tmp],
                    stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                    text=True, encoding="utf-8", errors="replace",
                    creationflags=subprocess.CREATE_NO_WINDOW  # ← konsol penceresi yok
                )
                for line in proc.stdout:
                    line = line.rstrip()
                    if line:
                        self.log_signal.emit(line)
                proc.wait()
                os.unlink(tmp)
            except Exception as e:
                self.log_signal.emit(f"LOG|HATA: {e}")

        self.done_signal.emit(True, f"{len(self.secilen)} klasör işlendi.")


class PathRow(QWidget):
    def __init__(self, tag, path, parent=None):
        super().__init__(parent)
        layout = QHBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(6)

        lbl_tag = QLabel(f"{tag}:")
        lbl_tag.setFont(QFont("Segoe UI", 9, QFont.Bold))
        lbl_tag.setFixedWidth(58)
        lbl_tag.setStyleSheet("color: #555;")

        lbl_val = QLabel(path)
        lbl_val.setFont(QFont("Segoe UI", 9))
        lbl_val.setStyleSheet("color: #222;")

        btn = QPushButton("📁")
        btn.setFixedSize(24, 24)
        btn.setCursor(Qt.PointingHandCursor)
        btn.setToolTip(f"Klasörü aç: {path}")
        btn.setStyleSheet("""
            QPushButton { border: none; background: transparent; font-size: 14px; }
            QPushButton:hover { background: #dde4f5; border-radius: 3px; }
        """)
        btn.clicked.connect(lambda: self._open(path))

        layout.addWidget(lbl_tag)
        layout.addWidget(lbl_val, 1)
        layout.addWidget(btn)

    def _open(self, path):
        if not os.path.isdir(path):
            os.makedirs(path, exist_ok=True)
        os.startfile(path)


